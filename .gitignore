# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
venv/
.venv/
env/

# --- Ortam & gizli anahtarlar (ASLA commit etme) ---
.env
*.json          # GCP servis hesabı anahtarları buraya düşmesin
!config/*.json  # config altındaki örnek/şablon json'lara izin ver
credentials/
*-key.json
service-account*.json

# --- Büyük veri dosyaları (git yerine local/Drive'da tutun) ---
data/*.csv
data/*.parquet
data/*.json
data/raw/
data/processed/
!data/.gitkeep

# --- Modeller ---
models/*.joblib
models/*.pkl
!models/.gitkeep

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
